# ========================================
# Configuração de Banco de Dados
# ========================================

# Driver: sqlite, postgres ou mysql
DB_DRIVER=sqlite

# SQLite
DB_PATH=./data/app.db

# PostgreSQL / MySQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=awesome_password
DB_NAME=awesome_db

# MySQL específico
MYSQL_ROOT_PASSWORD=root_password

# ========================================
# Configuração da Aplicação
# ========================================

PORT=8080
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_mudar_em_producao

# ========================================
# Exemplos de Configuração
# ========================================

# SQLite (desenvolvimento local)
# DB_DRIVER=sqlite
# DB_PATH=./data/app.db

# PostgreSQL (docker-compose)
# DB_DRIVER=postgres
# DB_HOST=postgres
# DB_PORT=5432

# MySQL (docker-compose)
# DB_DRIVER=mysql
# DB_HOST=mysql
# DB_PORT=3306
